# Sao chép thành .env hoặc .env.local rồi điền giá trị (không commit file có key thật).
# Trên Vercel: Settings → Environment Variables — dùng cùng tên biến.

# --- OpenAI (fallback khi Gemini; trình duyệt gọi qua /api/openai-chat — không gọi trực tiếp api.openai.com) ---
# Dev: Vite proxy đọc key này. Production (Vercel): thêm cùng biến cho serverless api/openai-chat.ts
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_API_KEY=

# --- Gemini (xoay vòng nhiều key; embedData / gemini-core dùng) ---
# Key lấy tại https://aistudio.google.com/apikey — dán nguyên chuỗi, không thêm dấu ngoặc / khoảng trắng thừa
VITE_GEMINI_API_KEY_1=
VITE_GEMINI_API_KEY_2=
VITE_GEMINI_MODEL=gemini-1.5-flash

# --- Google APIs (Drive Picker, Vision OCR, …) ---
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_PICKER_API_KEY=
VITE_GOOGLE_CLOUD_VISION_API_KEY=
# OAuth Picker (nếu dùng Google Picker đầy đủ)
VITE_GOOGLE_PICKER_CLIENT_ID=
VITE_GOOGLE_PICKER_APP_ID=
