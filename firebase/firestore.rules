rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerCreate() {
      return request.resource.data.userEmail == request.auth.token.email;
    }

    function isOwnerExisting() {
      return resource.data.userEmail == request.auth.token.email;
    }

    match /cvHistory/{docId} {
      allow get, list: if isSignedIn() && isOwnerExisting();
      allow create: if isSignedIn()
        && isOwnerCreate()
        && request.resource.data.timestamp is int
        && request.resource.data.createdAt is timestamp;
      allow update: if isSignedIn()
        && isOwnerExisting()
        && request.resource.data.userEmail == resource.data.userEmail;
      allow delete: if isSignedIn() && isOwnerExisting();
    }

    // Uploaded Files - CV & JD metadata
    match /uploadedFiles/{docId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Chatbot Sessions - conversation history
    match /chatbotSessions/{docId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Generic fallback for other collections
    match /{collection}/{docId} {
      allow read, write: if isSignedIn();
    }

  }
}